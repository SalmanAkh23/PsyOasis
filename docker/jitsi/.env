# Jitsi local development config
CONFIG=~/.jitsi-meet-cfg
TZ=Asia/Jakarta
HTTP_PORT=8000
HTTPS_PORT=0
PUBLIC_URL=http://localhost:8000
ENABLE_LETSENCRYPT=0
ENABLE_HTTP_REDIRECT=0
ENABLE_AUTO_UPGRADE=0
DOCKER_HOST_ADDRESS=127.0.0.1
XMPP_DOMAIN=localhost
XMPP_AUTH_DOMAIN=auth.localhost
XMPP_GUEST_DOMAIN=guest.localhost
XMPP_MUC_DOMAIN=muc.localhost
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.localhost
XMPP_RECORDER_DOMAIN=recorder.localhost
JICOFO_COMPONENT_SECRET=psyoasis-jitsi-secret
JICOFO_AUTH_PASSWORD=psyoasis-jicofo-pass
JVB_AUTH_PASSWORD=psyoasis-jvb-pass
JIGASI_XMPP_PASSWORD=psyoasis-jigasi-pass
JVB_PORT=10000
JVB_TCP_PORT=4443
JVB_STUN_SERVERS=stun.l.google.com:19302,stun1.l.google.com:19302
JVB_ENABLE_APIS=rest
JIGASI_ENABLE_SIP=0
